# =============================================================================
# config.toml.example — EasyVault configuration template
#
# Copy to config.toml (or point EASYVAULT_CONFIG at it) and edit.
# =============================================================================

[server]
address = "0.0.0.0"
port = 8200                        # match HashiCorp Vault default
tls = false                        # set true to serve HTTPS
# When tls = true and these are empty, a self-signed cert (localhost, 127.0.0.1)
# is generated on first run under <data_dir>/tls and reused thereafter. Supply
# real PEM paths for production.
tls_cert = ""
tls_key = ""

[storage]
type = "sqlite"                    # "sqlite" (default) or "postgres" (future)
# Absolute paths are used as-is. A relative path (the default) is anchored to
# the EasyVault data dir ($EASYVAULT_HOME, else $HOME/.easyvault) so the database
# is the same no matter which directory you launch the server from.
path = "easyvault.db"              # -> ~/.easyvault/easyvault.db by default
url = ""                           # postgres DSN (future)

[security]
session_ttl_hours = 8
max_login_attempts = 5
lockout_minutes = 15
trusted_proxies = ["127.0.0.1"]    # honoured for X-Forwarded-For

[audit]
enabled = true
log_raw_values = false             # NEVER set to true in production
easylog_url = ""

[init]
default_key_shares = 5
default_key_threshold = 3
